# ─────────────────────────────────────────────────────────────────────────────
# IELTS Studio 环境变量示例模板
#
# 用途：复制本文件为 .env（根目录）并填入实际值；.env 已在 .gitignore 中，不会被提交。
# 后端 Spring Boot 通过 ${ENV_VAR:default} 语法读取；前端 Vite 读取 VITE_ 前缀变量。
#
# ⚠️ 严禁提交真实 API Key / 数据库密码 / JWT secret / 加密密钥到 Git。
# ⚠️ 生产环境必须替换所有标记为 change-me 的占位值。
# ─────────────────────────────────────────────────────────────────────────────

# ─── Backend server ─────────────────────────────
SERVER_PORT=8080
# 生产建议设为 prod；本地开发可留空或设为 local（加载 application-local.yml）
SPRING_PROFILES_ACTIVE=

# ─── Database（MySQL 8）──────────────────────────
# 完整 JDBC 连接 URL；生产环境请使用专用账号与强密码，禁止使用 root/空密码
DB_URL=jdbc:mysql://localhost:3306/ielts_studio?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=ielts_studio
DB_PASSWORD=change-me

# ─── Security ───────────────────────────────────
# JWT 签名密钥：生产必须注入 64 位以上随机字符串，禁止使用开发默认值
JWT_SECRET=change-me-please-use-64-random-chars-or-more
# 用户自填 API Key 的 AES/GCM 加密密钥：生产必须注入 32 位以上随机字符串
# ⚠️ 更换该 secret 后，user_ai_settings 表中已加密的旧 key 将无法解密，需让用户重新填写
AI_KEY_ENCRYPTION_SECRET=change-me-please-use-32-random-chars-or-more

# ─── 内置管理员初始化（可选）──────────────────────
# 启动时若库中不存在任何 ADMIN（含禁用），且三项均已配置，则自动创建一个内置 ADMIN。
# 幂等：首次创建后，后续重启即使保留配置也不会重复创建。
# ⚠️ 初始化完成后建议清空这些值；后续改密码走后台「用户管理」。
INIT_ADMIN_USERNAME=
INIT_ADMIN_EMAIL=
INIT_ADMIN_PASSWORD=

# ─── CORS（生产必填）──────────────────────────────
# 前端实际域名（逗号分隔）；留空时仅允许 localhost/127.0.0.1（仅本地开发）
CORS_ALLOWED_ORIGINS=https://example.com

# ─── Redis 分布式限流（可选）──────────────────────
# 多实例部署必须设为 true；单实例可设为 false 走内存限流
APP_REDIS_ENABLED=false
SPRING_DATA_REDIS_HOST=127.0.0.1
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=
SPRING_DATA_REDIS_DATABASE=0

# ─── Built-in AI providers（BUILTIN 模式必填；USER 模式不需要）──────────────
# DeepSeek：文本解析 / 写作评分 / AI 助手 / 翻译 / 完形填空
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 精准解析提供方选择：mimo（默认）/ qwen
AI_PRECISE_PROVIDER=mimo

# 小米 MiMO（OpenAI 兼容，图表/表格场景更佳）
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5

# 通义千问 Qwen（通用视觉解析）
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.6-plus

# ─── MinIO 对象存储（可选，预留扩展）──────────────────
# 当前版本文件以内存字节处理为主，MinIO 未实际启用；
# 如启用，生产必须替换默认 minioadmin/minioadmin123
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me
MINIO_BUCKET_NAME=ielts-studio

# ─── Frontend（Vite）──────────────────────────────
# 后端 API 基础地址；本地开发可走 Vite 代理时留空使用 /api
VITE_API_BASE_URL=http://localhost:8080/api
